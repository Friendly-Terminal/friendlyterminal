{
  "name": "friendlyterminal-linux",
  "version": "1.2.0",
  "description": "A friendly, modern terminal for Linux",
  "author": "FriendlyTerminal contributors",
  "license": "GPL-3.0-only",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build": "npm run clean && npm run typecheck && node scripts/build.mjs",
    "clean": "node scripts/clean.mjs",
    "dev": "npm run build && electron .",
    "start": "electron .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "package": "npm run build && electron-builder --linux AppImage deb rpm",
    "package:dir": "npm run build && electron-builder --linux dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "electron": "^43.1.0",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.6",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.friendlyterminal.app",
    "productName": "FriendlyTerminal",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "files": [
      "dist/**",
      "package.json",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "resources/shell/bash-integration.bash",
        "to": "shell/bash-integration.bash"
      },
      {
        "from": "resources/shell/zsh/.zprofile",
        "to": "shell/zsh/.zprofile"
      },
      {
        "from": "resources/shell/zsh/.zshrc",
        "to": "shell/zsh/.zshrc"
      },
      {
        "from": "resources/shell/zsh/.zlogin",
        "to": "shell/zsh/.zlogin"
      }
    ],
    "directories": {
      "output": "release",
      "buildResources": "assets"
    },
    "linux": {
      "category": "System;TerminalEmulator",
      "executableName": "friendlyterminal",
      "icon": "assets/icon.png",
      "artifactName": "FriendlyTerminal-${version}-${arch}.${ext}",
      "synopsis": "A terminal designed to help you succeed",
      "description": "A modern Linux terminal with tabs, split panes, file navigation, Git context, command discovery, and a real PTY.",
      "desktop": {
        "entry": {
          "Name": "FriendlyTerminal",
          "Comment": "A terminal designed to help you succeed",
          "Keywords": "terminal;shell;console;command;developer;"
        }
      },
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    }
  }
}
