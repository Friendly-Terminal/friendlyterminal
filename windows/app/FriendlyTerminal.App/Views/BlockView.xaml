<UserControl
    x:Class="FriendlyTerminal.App.Views.BlockView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel>
        <Grid
            x:Name="HeaderRow"
            Padding="8,5"
            ColumnSpacing="8"
            CornerRadius="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Button
                x:Name="ExpandButton"
                Width="24"
                Height="24"
                Padding="0"
                AutomationProperties.Name="Collapse or expand output"
                Background="Transparent"
                BorderThickness="0"
                Click="OnToggleExpand">
                <FontIcon x:Name="Chevron" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="10" Glyph="&#xE70D;" />
            </Button>

            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="12"
                FontWeight="Bold"
                Opacity="0.6"
                Text="&gt;" />

            <TextBlock
                x:Name="CommandText"
                Grid.Column="2"
                VerticalAlignment="Center"
                FontFamily="Consolas"
                FontSize="13"
                TextTrimming="CharacterEllipsis" />

            <StackPanel
                Grid.Column="3"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="6">
                <TextBlock
                    x:Name="DurationText"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Opacity="0.55"
                    Visibility="Collapsed" />
                <ProgressRing
                    x:Name="RunningRing"
                    Width="14"
                    Height="14"
                    IsActive="False"
                    Visibility="Collapsed" />
                <FontIcon
                    x:Name="CheckIcon"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    FontSize="11"
                    Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                    Glyph="&#xE73E;"
                    Visibility="Collapsed" />
                <Border
                    x:Name="ExitBadge"
                    Padding="6,2"
                    Background="{ThemeResource SystemFillColorCriticalBrush}"
                    CornerRadius="4"
                    Visibility="Collapsed">
                    <TextBlock x:Name="ExitBadgeText" FontSize="10" FontWeight="SemiBold" Foreground="White" />
                </Border>
            </StackPanel>

            <Button
                x:Name="RerunButton"
                Grid.Column="4"
                Width="24"
                Height="24"
                Padding="0"
                AutomationProperties.Name="Re-run this command"
                Background="Transparent"
                BorderThickness="0"
                Click="OnRerun"
                ToolTipService.ToolTip="Re-run this command">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <ContentPresenter x:Name="OutputHost" Margin="28,2,8,4" />

        <StackPanel
            x:Name="AdviceBar"
            Margin="28,0,8,6"
            Orientation="Horizontal"
            Spacing="6"
            Visibility="Collapsed" />

        <StackPanel
            x:Name="UndoBar"
            Margin="28,0,8,6"
            Orientation="Horizontal"
            Spacing="6"
            Visibility="Collapsed" />

        <Border
            Height="1"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}"
            Opacity="0.5" />
    </StackPanel>
</UserControl>
