<UserControl
    x:Class="FriendlyTerminal.App.Views.CommandBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Padding="12,8,12,10" Spacing="6">
        <InfoBar
            x:Name="PasteNotice"
            FontSize="12"
            IsClosable="True"
            IsOpen="False"
            Severity="Informational" />

        <TextBlock
            x:Name="CompletionHints"
            MaxLines="2"
            FontFamily="Consolas"
            FontSize="11"
            Opacity="0.7"
            TextTrimming="CharacterEllipsis"
            TextWrapping="Wrap"
            Visibility="Collapsed" />

        <Grid ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox
                x:Name="Input"
                AllowDrop="True"
                AutomationProperties.Name="Command input"
                DragOver="OnDragOver"
                Drop="OnDrop"
                FontFamily="Consolas"
                FontSize="14"
                IsSpellCheckEnabled="False"
                KeyDown="OnKeyDown"
                Paste="OnPaste"
                PlaceholderText="Run a command…" />

            <Button
                x:Name="SendButton"
                Grid.Column="1"
                Width="38"
                Height="32"
                Padding="0"
                AutomationProperties.Name="Run command"
                Click="OnSend"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="Run (Enter)">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="13" Glyph="&#xE724;" />
            </Button>
        </Grid>
    </StackPanel>
</UserControl>
