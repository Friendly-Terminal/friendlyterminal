<UserControl
    x:Class="FriendlyTerminal.App.Views.SidebarColumnView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:FriendlyTerminal.App.Views">

    <Grid Background="{ThemeResource SolidBackgroundFillColorBase}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:FileSidebarView x:Name="FilesView" Grid.Row="0" />
        <Border Grid.Row="1" Height="1" HorizontalAlignment="Stretch" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <Grid Grid.Row="2">
            <views:ClaudeControlBarView x:Name="ClaudeBar" Visibility="Collapsed" />
            <views:InteractiveHintView x:Name="HintView" Visibility="Collapsed" />
            <Grid x:Name="HelpStack">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <views:ProjectCommandsView x:Name="ProjectView" />
                <views:CommandHelpView x:Name="HelpView" Grid.Row="1" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
