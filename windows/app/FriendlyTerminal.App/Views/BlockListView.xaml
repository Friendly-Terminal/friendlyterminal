<UserControl
    x:Class="FriendlyTerminal.App.Views.BlockListView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer x:Name="Scroller" Padding="12,8" VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <StackPanel x:Name="BlocksPanel" />

            <StackPanel
                x:Name="RunningRow"
                Padding="4,8"
                Orientation="Horizontal"
                Spacing="10"
                Visibility="Collapsed">
                <ProgressRing
                    Width="16"
                    Height="16"
                    IsActive="True" />
                <Button
                    Padding="6,2"
                    AutomationProperties.Name="Stop this command"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="OnStop"
                    ToolTipService.ToolTip="Stop this command (sends Ctrl+C)">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="10"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Glyph="&#xE71A;" />
                        <TextBlock
                            FontSize="11"
                            FontWeight="Medium"
                            Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                            Text="Stop" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel
                x:Name="EmptyHint"
                Padding="8,24"
                HorizontalAlignment="Center"
                Spacing="6">
                <FontIcon
                    HorizontalAlignment="Center"
                    FontFamily="{StaticResource SymbolThemeFontFamily}"
                    FontSize="22"
                    Opacity="0.4"
                    Glyph="&#xE756;" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="12"
                    Opacity="0.6"
                    Text="Type a command below to get started." />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
