<UserControl
    x:Class="FriendlyTerminal.App.Views.TerminalPaneView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:views="using:FriendlyTerminal.App.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
            x:Name="FocusStrip"
            Grid.Row="0"
            Height="2"
            HorizontalAlignment="Stretch"
            Background="{ThemeResource AccentTextFillColorPrimaryBrush}"
            Visibility="Collapsed" />

        <Grid
            x:Name="PaneHeader"
            Grid.Row="1"
            Padding="10,5"
            ColumnSpacing="6"
            Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon
                x:Name="PaneHeaderIcon"
                FontFamily="{StaticResource SymbolThemeFontFamily}"
                FontSize="11"
                Glyph="&#xE756;" />
            <TextBlock
                x:Name="PaneTitle"
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="11"
                TextTrimming="CharacterEllipsis" />
            <Button
                x:Name="CloseButton"
                Grid.Column="2"
                Width="22"
                Height="22"
                Padding="0"
                AutomationProperties.Name="Close this terminal"
                Background="Transparent"
                BorderThickness="0"
                Click="OnCloseClicked"
                ToolTipService.ToolTip="Close this terminal">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="9" Glyph="&#xE711;" />
            </Button>
        </Grid>

        <Grid Grid.Row="2">
            <views:BlockListView x:Name="BlockList" />
            <controls:WebView2
                x:Name="Xterm"
                AutomationProperties.HelpText="PowerShell session"
                AutomationProperties.Name="Terminal"
                Visibility="Collapsed" />
        </Grid>

        <Border
            Grid.Row="3"
            BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
            BorderThickness="0,1,0,0">
            <views:CommandBarView x:Name="CommandBar" />
        </Border>
    </Grid>
</UserControl>
