<UserControl
    x:Class="FriendlyTerminal.App.Views.ClaudeControlBarView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <StackPanel Padding="12,8,12,6">
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <FontIcon
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="12"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Glyph="&#xE99A;" />
                    <TextBlock
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontSize="11"
                        FontWeight="SemiBold"
                        Text="Claude Code" />
                    <StackPanel
                        Grid.Column="2"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="4">
                        <Ellipse
                            Width="6"
                            Height="6"
                            Fill="{ThemeResource SystemFillColorSuccessBrush}" />
                        <TextBlock
                            FontSize="9"
                            FontWeight="Medium"
                            Opacity="0.7"
                            Text="Running" />
                    </StackPanel>
                </Grid>
                <TextBlock
                    x:Name="VersionText"
                    FontSize="9"
                    Opacity="0.5"
                    Visibility="Collapsed" />
            </StackPanel>

            <Border
                x:Name="DangerBanner"
                Padding="12,4"
                Background="{ThemeResource SystemFillColorCautionBackgroundBrush}"
                Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <FontIcon
                        FontFamily="{StaticResource SymbolThemeFontFamily}"
                        FontSize="9"
                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                        Glyph="&#xE7BA;" />
                    <TextBlock
                        FontSize="9"
                        FontWeight="Medium"
                        Foreground="{ThemeResource SystemFillColorCautionBrush}"
                        Text="Auto-approve mode — Claude can act without asking"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <StackPanel Padding="12,10" Spacing="8">
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Opacity="0.7"
                    Text="Navigate &amp; select" />
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Move selection up"
                        Click="OnArrowUp"
                        ToolTipService.ToolTip="Up arrow — move selection up">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE70E;" />
                    </Button>
                    <Button
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Move selection down"
                        Click="OnArrowDown"
                        ToolTipService.ToolTip="Down arrow — move selection down">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE70D;" />
                    </Button>
                </Grid>
                <Grid x:Name="NumberRow" ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <StackPanel Padding="12,10" Spacing="6">
                <TextBlock
                    FontSize="10"
                    FontWeight="SemiBold"
                    Opacity="0.7"
                    Text="Controls" />
                <Grid ColumnSpacing="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Button
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Send Enter"
                        Click="OnEnter"
                        ToolTipService.ToolTip="Send Enter / submit current input">
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <FontIcon HorizontalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE751;" />
                            <TextBlock HorizontalAlignment="Center" FontSize="9" Opacity="0.7" Text="Enter" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="1"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Stop current operation"
                        Click="OnStop"
                        ToolTipService.ToolTip="Ctrl+C — interrupt current operation">
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <FontIcon HorizontalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Foreground="{ThemeResource SystemFillColorCautionBrush}" Glyph="&#xE71A;" />
                            <TextBlock HorizontalAlignment="Center" FontSize="9" Opacity="0.7" Text="Stop" />
                        </StackPanel>
                    </Button>
                    <Button
                        Grid.Column="2"
                        HorizontalAlignment="Stretch"
                        AutomationProperties.Name="Send Escape"
                        Click="OnEscape"
                        ToolTipService.ToolTip="Escape — cancel / back">
                        <StackPanel HorizontalAlignment="Center" Spacing="3">
                            <FontIcon HorizontalAlignment="Center" FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE711;" />
                            <TextBlock HorizontalAlignment="Center" FontSize="9" Opacity="0.7" Text="Esc" />
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <StackPanel Padding="12,10" Spacing="6">
                <Button
                    Padding="0"
                    AutomationProperties.Name="Toggle slash commands"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="OnToggleSlash"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Stretch">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            FontSize="10"
                            FontWeight="SemiBold"
                            Opacity="0.7"
                            Text="Slash commands" />
                        <FontIcon
                            x:Name="SlashChevron"
                            Grid.Column="1"
                            FontFamily="{StaticResource SymbolThemeFontFamily}"
                            FontSize="9"
                            Opacity="0.5"
                            Glyph="&#xE70D;" />
                    </Grid>
                </Button>
                <Grid
                    x:Name="SlashGrid"
                    ColumnSpacing="6"
                    RowSpacing="6"
                    Visibility="Collapsed">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                </Grid>
            </StackPanel>

            <Border Height="1" Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <StackPanel Padding="12,10" Spacing="4">
                <Button
                    HorizontalAlignment="Stretch"
                    AutomationProperties.Name="Exit Claude"
                    Click="OnExit"
                    ToolTipService.ToolTip="Send /exit — end the Claude session">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE7E8;" />
                        <TextBlock FontSize="11" FontWeight="Medium" Text="Exit Claude" />
                    </StackPanel>
                </Button>
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="9"
                    Opacity="0.5"
                    Text="or press Ctrl+C twice" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
