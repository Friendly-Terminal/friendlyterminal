<UserControl
    x:Class="FriendlyTerminal.App.Views.GitPanelView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="440"
    MinHeight="380">

    <Grid RowSpacing="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="300" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="BranchText"
                VerticalAlignment="Center"
                FontSize="12"
                Opacity="0.7" />
            <ProgressRing
                x:Name="BusyRing"
                Grid.Column="1"
                Width="16"
                Height="16"
                IsActive="False" />
            <Button
                x:Name="HelpButton"
                Grid.Column="2"
                Width="30"
                Height="30"
                Padding="0"
                AutomationProperties.Name="What these words mean"
                ToolTipService.ToolTip="New to Git? What these words mean">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE897;" />
                <Button.Flyout>
                    <Flyout>
                        <StackPanel MaxWidth="320" Spacing="8">
                            <TextBlock FontSize="13" FontWeight="SemiBold" Text="Git in a nutshell" />
                            <TextBlock
                                FontSize="11"
                                Opacity="0.75"
                                Text="Git saves snapshots of your project so you can track changes and share them. The usual flow is stage, then commit, then push."
                                TextWrapping="Wrap" />
                            <TextBlock FontSize="11" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Stage" /><LineBreak /><Run Text="Pick which changed files go into your next save (the checkboxes here). 'Add' means the same thing." />
                            </TextBlock>
                            <TextBlock FontSize="11" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Commit" /><LineBreak /><Run Text="Save a snapshot of the staged files, with a short message describing what changed." />
                            </TextBlock>
                            <TextBlock FontSize="11" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Push" /><LineBreak /><Run Text="Upload your commits to GitHub so they're backed up and others can see them." />
                            </TextBlock>
                            <TextBlock FontSize="11" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Pull" /><LineBreak /><Run Text="Download the latest commits other people have pushed, into your copy." />
                            </TextBlock>
                            <TextBlock FontSize="11" TextWrapping="Wrap">
                                <Run FontWeight="SemiBold" Text="Branch" /><LineBreak /><Run Text="A separate line of work you can switch to, so changes don't affect the main version until you're ready." />
                            </TextBlock>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
            <Button
                x:Name="RefreshButton"
                Grid.Column="3"
                Width="30"
                Height="30"
                Padding="0"
                AutomationProperties.Name="Refresh"
                Click="OnRefresh"
                ToolTipService.ToolTip="Refresh">
                <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="12" Glyph="&#xE72C;" />
            </Button>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                x:Name="SummaryText"
                VerticalAlignment="Center"
                FontSize="11"
                Opacity="0.7" />
            <HyperlinkButton
                x:Name="StageAllButton"
                Grid.Column="1"
                Padding="0"
                Click="OnStageAll"
                Content="Stage all"
                FontSize="11" />
        </Grid>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ChangesPanel" Spacing="2" />
        </ScrollViewer>

        <StackPanel
            x:Name="EmptyPanel"
            Grid.Row="2"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Spacing="8"
            Visibility="Collapsed">
            <FontIcon
                x:Name="EmptyIcon"
                HorizontalAlignment="Center"
                FontFamily="{StaticResource SymbolThemeFontFamily}"
                FontSize="24"
                Opacity="0.5"
                Glyph="&#xE73E;" />
            <TextBlock
                x:Name="EmptyText"
                HorizontalAlignment="Center"
                FontSize="12"
                Opacity="0.6"
                TextAlignment="Center"
                TextWrapping="Wrap" />
            <HyperlinkButton
                x:Name="GitInitButton"
                HorizontalAlignment="Center"
                Click="OnGitInit"
                Content="Start tracking with Git"
                FontSize="12"
                Visibility="Collapsed" />
        </StackPanel>

        <StackPanel Grid.Row="3" Spacing="8">
            <TextBox
                x:Name="CommitMessage"
                AutomationProperties.Name="Commit message"
                PlaceholderText="Commit message"
                TextChanged="OnMessageChanged" />
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button
                    x:Name="CommitButton"
                    HorizontalAlignment="Stretch"
                    Click="OnCommit"
                    Content="Commit"
                    IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}" />
                <Button
                    x:Name="PushButton"
                    Grid.Column="1"
                    Click="OnPush"
                    ToolTipService.ToolTip="Push commits to the remote (runs in the terminal so you can sign in if needed)">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="11" Glyph="&#xE74A;" />
                        <TextBlock x:Name="PushLabel" FontSize="12" Text="Push" />
                    </StackPanel>
                </Button>
            </Grid>
        </StackPanel>
    </Grid>
</UserControl>
