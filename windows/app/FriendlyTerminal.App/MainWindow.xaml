<Window
    x:Class="FriendlyTerminal.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:FriendlyTerminal.App.Views"
    Title="FriendlyTerminal">
    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <views:BreadcrumbBarView x:Name="Breadcrumb" Grid.Row="0" />
        <Border
            Grid.Row="0"
            Height="1"
            VerticalAlignment="Bottom"
            Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                x:Name="SidebarHost"
                Width="280"
                Background="{ThemeResource SolidBackgroundFillColorBase}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,0,1,0">
                <views:SidebarColumnView x:Name="Sidebar" />
            </Border>

            <Grid
                x:Name="PaneHost"
                Grid.Column="1"
                ColumnSpacing="1" />
        </Grid>
    </Grid>
</Window>
